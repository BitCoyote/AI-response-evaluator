{
  "name": "ai-response-evaluator",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c green,blue \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "uvicorn app.main:app --app-dir backend --reload --port 8000",
    "dev:frontend": "npm run dev --prefix frontend",
    "seed": "python backend/seed_data.py"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
